[alias]
   stat = status
   addtag = tag
   edittag = !f() {\
    local __tag="$1"\
    local __remote="$2"\
    git tag --delete "${__tag}"\
    git push --delete "${__remote}" tag "${__tag}"\
    git addtag ${__tag} \
    git push "${__remote}" --tags \
   }
   deltag = !f() {\
    local __tag="$1"\
    local __remote="$2"\
    git tag --delete "${__tag}"\
    git push --delete "${__remote}" tag "${__tag}"\
   }
	firstcom = commit --allow-empty -m \"Initial commit\"

